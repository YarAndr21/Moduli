def xc(d, k):
    if isinstance(d, str):
        d = d.encode('utf-8')
    kb = k.encode('utf-8')
    ext_kb = (kb * (len(d) // len(kb) + 1))[:len(d)]
    return bytes(a ^ b for a, b in zip(d, ext_kb))
