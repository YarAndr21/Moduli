from PIL import Image
def bt(t):
    return ''.join(format(ord(c), '08b') for c in t) + '1111111111111110'
def tb(b):
    c = [chr(int(b[i:i+8], 2)) for i in range(0, len(b), 8)]
    return ''.join(c).split('\xfe')[0]
def h(n, t, o):
    i = Image.open(n)
    p = i.load()
    b = bt(t)
    w, hh = i.size
    k = 0
    for x in range(w):
        for y in range(hh):
            r, g, bv = p[x, y]
            if k < len(b):
                r = (r & 254) | int(b[k]); k += 1
            if k < len(b):
                g = (g & 254) | int(b[k]); k += 1
            if k < len(b):
                bv = (bv & 254) | int(b[k]); k += 1
            p[x, y] = (r, g, bv)
    i.save(o)
    print(f"Спрятано {len(t)} символов")
def e(n):
    i = Image.open(n)
    p = i.load()
    b = ''
    w, hh = i.size
    for x in range(w):
        for y in range(hh):
            r, g, bv = p[x, y]
            b += str(r & 1) + str(g & 1) + str(bv & 1)
            if '1111111111111110' in b:
                return tb(b[:b.find('1111111111111110')])
    return tb(b)
print("Начинаем расшифровку")
