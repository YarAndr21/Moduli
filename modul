import string 
def gen_pw(l=12):
    ch = al + d + p
    return ''.join(random.choice(ch) for _ in range(l))
def eval_pw(pw):
    tc = 0
    if any(c.islower() for c in pw): tc += 26
    if any(c.isupper() for c in pw): tc += 26
    if any(c.isdigit() for c in pw): tc += 10
    if any(c in p for c in pw): tc += 32
    ent = len(pw) * math.log2(tc or 1)
    if ent < 30:
        st = "слабый"
    elif ent < 50:
        st = "средний"
    else:
        st = "сильный"

    return round(ent, 2), st

