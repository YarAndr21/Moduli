def compute_hash(text):
    return sum(ord(char) for char in text) % 10000
def find_matches(hash_value):
    return [f"{num:04d}" for num in range(10000) if compute_hash(f"{num:04d}") == hash_value]
user_hash = int(input("Введите хеш (число от 0 до 9999): "))
